#############################################
# APPLICATION CONFIG
#############################################

APP_NAME="Rafeeq AI"
ENV=development
DEBUG=true
LOG_LEVEL=info
DEFAULT_LANGUAGE=ar

#############################################
# SERVER CONFIG
#############################################

HOST=0.0.0.0
PORT=8000

#############################################
# REDIS (CACHE / MEMORY LAYER)
#############################################

REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

#############################################
# VECTOR DATABASE (QDRANT)
#############################################

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=medical_rag

#############################################
# EMBEDDING MODEL
#############################################

EMBEDDING_MODEL=intfloat/multilingual-e5-base

#############################################
# LLM PROVIDERS
#############################################

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Groq (Fast Inference)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODELS=llama-3.3-70b-versatile,llama3-8b-8192

# OpenRouter (Fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODELS=deepseek/deepseek-chat-v3-0324,google/gemma-3-27b-it:free

#############################################
# HUGGING FACE
#############################################

HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here



#############################################
# PERFORMANCE TUNING
#############################################

MAX_WORKERS=4
CACHE_TTL=3600
EMBEDDING_BATCH_SIZE=32

#############################################
# FEATURE FLAGS
#############################################

USE_GEMINI=true
USE_GROQ=true
USE_OPENROUTER=true
USE_HF=true

#############################################
# MEDICAL SYSTEM CONFIG
#############################################

EMERGENCY_MODE_ENABLED=true
RAG_TOP_K=3
DEFAULT_LLM_ROUTE=fast